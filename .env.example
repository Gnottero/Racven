# Copia questo file in .env (o esporta le variabili nell'ambiente) prima del deploy.

# Chiave segreta per firmare le sessioni Flask. Genera un valore casuale con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Percorso del file SQLite. Se non impostato, viene usato <repo>/database.db
DATABASE_PATH=

# Intervalli di visualizzazione sulla TV (in secondi)
TV_CAROUSEL_INTERVAL_SECONDS=6
TV_MESSAGE_DISPLAY_SECONDS=8
TV_DUTY_DISPLAY_SECONDS=15
